{
  "name": "@ooakloo/docs-engine",
  "version": "0.6.0",
  "private": false,
  "type": "module",
  "description": "Shared document semantics, React primitives and visual system for ooAKLoo projects.",
  "sideEffects": [
    "*.css",
    "styles/*.css"
  ],
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/docusaurus": {
      "types": "./dist/adapters/docusaurus.d.ts",
      "import": "./dist/adapters/docusaurus.js",
      "default": "./dist/adapters/docusaurus.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "import": "./dist/model.js",
      "default": "./dist/model.js"
    },
    "./styles.css": "./styles/index.css",
    "./tokens.css": "./styles/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.mjs",
    "check": "pnpm typecheck && pnpm build && pnpm test",
    "showcase": "vite showcase --host 127.0.0.1 --port 3200",
    "showcase:typecheck": "tsc -p tsconfig.showcase.json --noEmit",
    "showcase:build": "vite build showcase --base=./"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.6.3",
    "vite": "^6.4.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "dependencies": {
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "motion": "^12.23.24"
  }
}
